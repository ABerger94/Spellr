DATABASE_URL="postgresql://spellr:spellr@localhost:5432/spellr"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: AI seats no-op gracefully if this is unset
GEMINI_API_KEY=""

# Required for realtime multiplayer sync — create a free app at
# https://dashboard.pusher.com (Channels product) and paste its credentials
# here. NEXT_PUBLIC_* vars are exposed to the browser (that's expected —
# they're a publishable key/cluster, not a secret).
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""
