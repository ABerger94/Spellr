DATABASE_URL="postgresql://spellr:spellr@localhost:5432/spellr"
# Only needs a different value than DATABASE_URL when DATABASE_URL is a pooled
# connection (e.g. Supabase's PgBouncer pooler on port 6543) — Prisma Migrate
# needs a direct connection. For local Postgres, just copy DATABASE_URL here too.
DIRECT_URL="postgresql://spellr:spellr@localhost:5432/spellr"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: AI seats no-op gracefully (log why, then pass) if none of the
# keys below are set. Whichever are set are tried in this order — Gemini,
# Groq, Cerebras, OpenRouter, Base44 — falling through to the next only if a
# call errors (bad key, rate limit, outage, etc). All five have permanently
# free tiers, so setting more than one gives the AI more headroom before it
# has to skip a turn. Each provider's free-tier limits are modest on their
# own (e.g. Groq: ~30 req/min; Cerebras: ~5 req/min, 1M tokens/day;
# OpenRouter free models: ~20 req/min, 50-1000 req/day) — stacking providers
# is what makes the AI reliable in practice.
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

# Free key at https://console.groq.com/keys
GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"

# Free key at https://cloud.cerebras.ai — very fast inference, small free
# model lineup that rotates (check the console for current model ids).
CEREBRAS_API_KEY=""
# CEREBRAS_MODEL="gpt-oss-120b"

# Free key at https://openrouter.ai/keys — "openrouter/free" auto-routes to
# whichever free, tool-calling-capable model is currently available, so it
# doesn't need updating as OpenRouter's free lineup changes.
OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="openrouter/free"

# App ID for a Base44 (https://base44.com) app — the same appId you'd find in
# that app's editor URL. This is the tried-last fallback: Base44's InvokeLLM
# is a stateless prompt-in/JSON-out call (no native multi-turn tool calling),
# so it's the least reliable of the five for a multi-step AI turn, but it's
# free to add as extra headroom. No separate secret key needed — anonymous
# access via appId alone is enough for InvokeLLM.
BASE44_APP_ID=""

# Required for realtime multiplayer sync — create a free app at
# https://dashboard.pusher.com (Channels product) and paste its credentials
# here. NEXT_PUBLIC_* vars are exposed to the browser (that's expected —
# they're a publishable key/cluster, not a secret).
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Optional — authorizes the scheduled idle-game cleanup at
# /api/cron/close-idle-games (see vercel.json). Generate with
# `openssl rand -base64 32` and set the same value as a Vercel project env
# var named CRON_SECRET; Vercel Cron then sends it automatically as
# `Authorization: Bearer $CRON_SECRET` on every scheduled call. Without this
# set, the route always rejects requests rather than running unauthenticated.
CRON_SECRET=""
