DATABASE_URL="postgresql://spellr:spellr@localhost:5432/spellr"
# Only needs a different value than DATABASE_URL when DATABASE_URL is a pooled
# connection (e.g. Supabase's PgBouncer pooler on port 6543) — Prisma Migrate
# needs a direct connection. For local Postgres, just copy DATABASE_URL here too.
DIRECT_URL="postgresql://spellr:spellr@localhost:5432/spellr"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: AI seats no-op gracefully (log why, then pass) if neither key
# below is set. When both are set, Gemini is tried first and Groq is used as
# a fallback if the Gemini call errors (bad key, quota, outage, etc).
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

# Optional fallback/alternative AI provider — get a free key at
# https://console.groq.com/keys
GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"

# Required for realtime multiplayer sync — create a free app at
# https://dashboard.pusher.com (Channels product) and paste its credentials
# here. NEXT_PUBLIC_* vars are exposed to the browser (that's expected —
# they're a publishable key/cluster, not a secret).
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""
